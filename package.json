{
  "name": "orael",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "dev": "concurrently -n server,client,bot -c blue,green,yellow \"npm:dev:server\" \"npm:dev:client\" \"node server/bot.js\"",
    "build": "vite build",
    "start:server": "node server/index.js",
    "start:bot": "node server/bot.js",
    "start": "concurrently -n server,bot -c blue,yellow \"npm:start:server\" \"npm:start:bot\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "sql.js": "^1.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "vite": "^6.3.5"
  }
}
